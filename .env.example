# Postgres
POSTGRES_USER=ha_user
POSTGRES_PASSWORD=change_me
POSTGRES_DB=home_automation
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Backend
DATABASE_URL=postgresql+asyncpg://ha_user:change_me@postgres:5432/home_automation
JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost,http://localhost:3000
HEARTBEAT_TIMEOUT_SECONDS=90
HEARTBEAT_POLL_INTERVAL_SECONDS=15

# MQTT
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=ha_backend
MQTT_PASSWORD=change_me

# Frontend
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/ws
